<!-- views/employee.hbs -->

<div class='max-w-3xl mx-auto px-6 py-8'>

  {{#if error}}
    <div class='bg-red-50 border border-red-200 text-red-600 px-4 py-3 rounded-lg mb-6'>
      {{error}}
    </div>
  {{/if}}

  <h2 class='text-lg font-bold text-gray-700 mb-4'>Tasks Assigned to Me</h2>

  {{#if tasks}}
    <div class='space-y-4'>
      {{#each tasks}}
        <div class='bg-white rounded-xl shadow p-5'>

          <!-- Task header: title and status badge -->
          <div class='flex justify-between items-start gap-4'>
            <div class='flex-1 min-w-0'>
              <h3 class='font-semibold text-gray-800'>{{this.title}}</h3>
              {{#if this.description}}
                <p class='text-sm text-gray-500 mt-1'>{{this.description}}</p>
              {{/if}}
              <p class='text-sm text-gray-400 mt-1'>
                Assigned by: <span class='font-medium'>{{this.createdBy.name}}</span>
              </p>
              {{#if this.deadline}}
                <p class='text-sm text-gray-400'>Deadline: {{this.deadline}}</p>
              {{/if}}
            </div>
            <span class='text-xs px-3 py-1 rounded-full font-medium shrink-0
                         {{statusClass this.status}}'>
              {{this.status}}
            </span>
          </div>

          <!-- Status update form: only shown if task is not yet completed -->
          {{#unless (eq this.status 'completed')}}
            <!-- action sends to Niyat's PUT /api/tasks/:id route -->
            <!-- The hidden _method input tells method-override to treat this as PUT -->
            <form action='/api/tasks/{{this._id}}' method='POST'
                  class='mt-4 flex items-center gap-3'>
              <input type='hidden' name='_method' value='PUT' />

              <select name='status'
                class='border border-gray-300 rounded-lg px-3 py-1 text-sm
                       focus:outline-none focus:ring-2 focus:ring-purple-500'>
                <!-- eq helper pre-selects whatever the current status is -->
                <option value='pending'
                  {{#if (eq this.status 'pending')}}selected{{/if}}>
                  Pending
                </option>
                <option value='in-progress'
                  {{#if (eq this.status 'in-progress')}}selected{{/if}}>
                  In Progress
                </option>
                <option value='completed'>Completed</option>
              </select>

              <button type='submit'
                class='bg-purple-700 text-white text-sm px-4 py-1 rounded-lg
                       hover:bg-purple-800 transition-colors font-medium'>
                Update
              </button>
            </form>

          {{else}}
            <!-- Task is complete: show a tick message instead of the form -->
            <p class='text-green-600 text-sm mt-3 font-medium'>Task completed</p>
          {{/unless}}
          
        </div>
      {{/each}}
    </div>
  {{else}}
    <div class='text-center py-16 text-gray-400'>
      <p class='text-4xl mb-3'>🎉</p>
      <p class='font-medium'>No tasks assigned to you yet.</p>
    </div>
  {{/if}}

</div>